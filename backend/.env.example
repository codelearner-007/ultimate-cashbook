# ── Supabase (required) ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # service_role key — NEVER the anon key
SUPABASE_JWT_SECRET=your_jwt_secret_here          # Project Settings → API → JWT Secret

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins, e.g. "https://app.example.com,https://admin.example.com".
# Leave as "*" for mobile-only; set explicit origins when serving the web build.
ALLOWED_ORIGINS=*

# ── RevenueCat (subscriptions) ─────────────────────────────────────────────────
# Shared secret the RevenueCat webhook must send as its Authorization header.
# This webhook is the ONLY writer of paid entitlements. Leave blank to disable it.
REVENUECAT_WEBHOOK_AUTH=

# Dev-only: allow the client to set its own subscription tier (PATCH /profile/subscription).
# MUST be false/blank in production — `true` reopens the self-upgrade hole. For local
# testing of tier-gated UI without a store sandbox only.
DEV_ALLOW_CLIENT_SUBSCRIPTION=false

# ── Error monitoring (optional) ────────────────────────────────────────────────
SENTRY_DSN=

# ── Gmail SMTP — production OTP email (leave blank in local dev → Supabase native OTP) ──
GMAIL_SMTP_USER=
GMAIL_SMTP_PASSWORD=
GMAIL_FROM_NAME=Ultimate CashBook
GMAIL_FROM_ADDRESS=info@ultimatecashbook.com
