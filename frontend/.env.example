EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
EXPO_PUBLIC_API_URL=http://localhost:8000

# ── Dev-only subscription override ─────────────────────────────────────────────
# Allowed values: free | pro | business   (leave blank or remove in production)
# When set, this overrides the real subscription tier for ALL feature gates and
# the local-vs-cloud data routing decision — no Supabase writes happen.
EXPO_PUBLIC_DEV_OVERRIDE_TIER=pro
