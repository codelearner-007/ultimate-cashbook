EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
EXPO_PUBLIC_API_URL=http://localhost:8000

# ── RevenueCat (subscriptions — native builds only) ────────────────────────────
# Public SDK keys from the RevenueCat dashboard (one per platform). Purchases are
# native-only (absent in Expo Go / web). Paid entitlements are applied server-side
# by the RevenueCat webhook, never set by the client.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ── Dev-only overrides (leave blank / remove in production) ─────────────────────
# Override the subscription tier for feature gates + data routing: free | pro | business
EXPO_PUBLIC_DEV_OVERRIDE_TIER=
# Force ALL data routing to local SQLite regardless of tier (true | blank)
EXPO_PUBLIC_DEV_OVERRIDE_LOCAL=
