{
  "expo": {
    "name": "Ultimate CashBook",
    "slug": "ultimate-cashbook",
    "scheme": "ultimatecashbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#EEF7F7"
    },
    "android": {
      "package": "com.ultimatecashbook.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#33AEB3"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "ultimatecashbook"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.ultimatecashbook.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Ultimate CashBook uses your camera to take photos for your profile and to attach receipts to entries.",
        "NSPhotoLibraryUsageDescription": "Ultimate CashBook accesses your photo library to set a profile photo and to attach receipt images to entries.",
        "NSContactsUsageDescription": "Ultimate CashBook accesses your contacts to quickly add customers and suppliers."
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Ultimate CashBook accesses your photos to set a profile photo and attach receipts to entries.",
          "cameraPermission": "Ultimate CashBook uses your camera to take a profile photo and capture receipts for entries."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3B5BDB",
          "defaultChannel": "default"
        }
      ],
      "expo-sqlite",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.729677181390-oi5va7a0s6tc2a6c8kv5tsu19cqk5sch"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "33fc45da-8b6f-4a39-afd5-fce89f765406"
      }
    },
    "owner": "ultimate-cashbook"
  }
}
